# Node dependencies
node_modules/
**/node_modules/

# Local environment variables containing secret keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local

# Production build outputs
dist/
**/dist/
build/
**/build/

# IDE configuration and temporary files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# System logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS-specific files
Thumbs.db
desktop.ini
.DS_Store

# Server uploads (ignore actual uploaded media files, keep directory structure)
server/uploads/*
!server/uploads/.gitkeep

# Design reference images (large AI-generated images, not needed in git)
logo and desing/
"logo and desing"/

# Large binary assets that are not code
*.pdf
download.pdf

# Root-level public folder (images live in buyer/public/ and seller/public/)
/public/
